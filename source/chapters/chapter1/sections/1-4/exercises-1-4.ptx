<exercises xml:id="exercises-1-4">
  <title>Exercises for Section 1.4</title>

  <exercise xml:id="ex-1-4-1">
    <statement>
      <p>
        Find the explicit general solution to the following differential equation:
        <me>(1 + x)\frac{dy}{dx} = 6y.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>y = C(1+x)^6</me>
      </p>
    </answer>
  </exercise>
<exercise xml:id="ex-1-4-2">
    <statement>
      <p>
        Find the explicit general solution of the given differential equation:
        <me>\frac{dy}{dx} + 6xy = 0.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>y = Ce^{-3x^2}</me>
      </p>
    </answer>
  </exercise>

  <exercise xml:id="ex-1-4-3">
    <statement>
      <p>
        Find the explicit general solution to the following differential equation:
        <me>\frac{dy}{dx} = ye^{7x}.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>y = Ce^{e^{7x}/7}</me>
      </p>
    </answer>
  </exercise>

  

  <exercise xml:id="ex-1-4-4">
    <statement>
      <p>
        Find the explicit general solution to the following differential equation:
        <me>y' = 9xy^3.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>y = \pm\frac{1}{\sqrt{-(9x^2 + C)}}</me>
        and
         <me>y = 0</me>
         Remember the general solution needs to include both any equilibrium solutions together with all solutions
         found from separation of variables.
      </p>
    </answer>
  </exercise>

  <exercise xml:id="ex-1-4-5">
    <introduction>
      <p>
        Consider the separable ODE:
        <me>y' = (y-3)^2 x.</me>
      </p>
    </introduction>
    <task xml:id="ex-1-4-5a">
      <statement>
        <p>
          Find all equilibrium solutions, then find the explicit general solution.
        </p>
      </statement>
      <answer>
        <p>
          Equilibrium: <m>y = 3</m>. 
          This together with separation of variables yields the general solution:
           <me>y = 3 - \dfrac{1}{x^2/2 + C} \text{ and } y=3</me>.
        </p>
      </answer>
    </task>
    <task xml:id="ex-1-4-5b">
      <statement>
        <p>
          Find the specific solution satisfying <m>y(0) = 3</m>.
        </p>
      </statement>
      <answer>
        <p>
          <m>y = 3</m> (the equilibrium solution).
        </p>
      </answer>
    </task>
    <task xml:id="ex-1-4-5c">
      <statement>
        <p>
          Find the specific solution satisfying <m>y(0) = 1</m>.
        </p>
      </statement>
      <answer>
        <p>
          <me>y = 3 - \frac{2}{x^2 - 1}</me>
        </p>
      </answer>
    </task>
  </exercise>

  <exercise xml:id="ex-1-4-6">
    <statement>
      <p>
        Find a general <alert>implicit solution</alert> to the following ODE:
        <me>p'(t) = \frac{1}{p} + \frac{\cos(t)}{p}.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>\frac{p^2}{2} = t + \sin(t) + C</me>
      </p>
    </answer>
  </exercise>

  <exercise xml:id="ex-1-4-7">
    <statement>
      <p>
        Solve the IVP explicitly:
        <me>(2x + 6)\frac{dx}{dt} = -t\sin(t^2), \quad x(0) = -4.</me>
      </p>
    </statement>
    <answer>
      <p>
        <me>x = -3 - \sqrt{\frac{\cos(t^2) - 17}{2} + 9}</me>
      </p>
    </answer>
  </exercise>

<exercise xml:id="ex-1-4-8">
    <statement>
      <p>
        After some ancient bones were excavated, carbon was taken from one of the bones to find that there was 68% as much <m>^{14}C</m> as from current bones. The decay constant of <m>^{14}C</m> is <m>k \approx 0.0001216</m>, for time in years. How many years old is the bone?
      </p>
    </statement>
    <answer>
      <p>
        The bone is approximately <m>3172</m> years old.
      </p>
    </answer>
  </exercise>

  <exercise xml:id="ex-1-4-9">
    <introduction>
      <p>
        The intensity of light <m>I</m> through a lake at a depth of <m>x</m> meters satisfies
        <me>\frac{dI}{dx} = -1.33I.</me>
      </p>
    </introduction>
    <task xml:id="ex-1-4-9a">
      <statement>
        <p>
          At what depth is the intensity of the light half that of the intensity at the surface <m>I_0</m>?
        </p>
      </statement>
      <answer>
        <p>
          <m>0.521</m> meters.
        </p>
      </answer>
    </task>
    <task xml:id="ex-1-4-9b">
      <statement>
        <p>
          At 5 meters deep, what is the intensity of the light as a fraction of <m>I_0</m>?
        </p>
      </statement>
      <answer>
        <p>
          <m>1.29 \times 10^{-3} I_0</m>
        </p>
      </answer>
    </task>
    <task xml:id="ex-1-4-9c">
      <statement>
        <p>
          At what depth will the intensity of light be 3% of the intensity at the surface?
        </p>
      </statement>
      <answer>
        <p>
          <m>2.64</m> meters.
        </p>
      </answer>
    </task>
  </exercise>

  <exercise xml:id="ex-1-4-10">
    <statement>
      <p>
        A cake is removed from an oven at <m>226^\circ</m>F and left to cool at room temperature, which is <m>73^\circ</m>F.
        After 29 minutes, the temperature of the cake is <m>159^\circ</m>F. When will it be <m>97^\circ</m>F?
      </p>
    </statement>
    <answer>
      <p>
        The cake will be at <m>97^\circ</m>F after approximately <m>93</m> minutes.
      </p>
    </answer>
  </exercise>

</exercises>