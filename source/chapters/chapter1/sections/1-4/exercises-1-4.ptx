<exercises xml:id="exercises-1-4">
  <title>Exercises for Section 1.4</title>

  <exercise xml:id="ex-1-4-1">
    <statement>
      <p>
        Find the explicit general solution to the following differential equation:
        <me>(1 + x)\frac{dy}{dx} = 6y.</me>
      </p>
    </statement>
  </exercise>

  <exercise xml:id="ex-1-4-2">
    <statement>
      <p>
        Find the explicit particular solution of the initial value problem:
        <me>\frac{dy}{dx} = ye^{7x}, \quad y(0) = 5e.</me>
      </p>
    </statement>
  </exercise>



  <exercise xml:id="ex-1-4-5">
    <statement>
      <p>
        Find the explicit general solution of the given differential equation:
        <me>\frac{dy}{dx} + 6xy = 0.</me>
      </p>
    </statement>
  </exercise>

  <exercise xml:id="ex-1-4-6">
    <statement>
      <p>
        Find the explicit general solution to the following differential equation:
        <me>y' = 9xy^{10}.</me>
      </p>
    </statement>
  </exercise>

  <exercise xml:id="ex-1-4-7">
  <introduction>
    <p>
      Consider the separable ODE:
      <me>y'(t) = \frac{y^2}{t^2}.</me>
    </p>
  </introduction>
  <task xml:id="ex-1-4-7a">
    <statement>
      <p>
        Find the explicit general solution.
      </p>
    </statement>
  </task>
  <task xml:id="ex-1-4-7b">
    <statement>
      <p>
        Find the specific solution satisfying the initial condition <m>y(0) = 3</m>.
      </p>
    </statement>
  </task>
  <task xml:id="ex-1-4-7c">
    <statement>
      <p>
        Find the specific solution satisfying the initial condition <m>y(0) = 0</m>.
      </p>
    </statement>
  </task>
</exercise>

<exercise xml:id="ex-1-4-implicit">
  <statement>
    <p>
      Find a general <alert>implicit solution</alert> to the following ODE:
      <me>p'(t) = \frac{1}{p} + \frac{\cos(t)}{p}.</me>
    </p>
  </statement>
</exercise>

  <exercise xml:id="ex-1-4-8">
    <statement>
      <p>
        Solve the IVP explicitly:
        <me>(2x + 6)\frac{dx}{dt} = -t\sin(t^2), \quad x(0) = -4.</me>
      </p>
    </statement>
  </exercise>

  <exercise>
    <statement>
      <p>
        More to be added for week 2 part of this section (the previous exercise also goes with week 2 homework)
      </p>
    </statement>
  </exercise>

  

</exercises>